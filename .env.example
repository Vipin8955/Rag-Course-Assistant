# ════════════════════════════════════════════════════════════════
#  .env.example — University Course Assistant
#  Copy this file to .env and adjust values as needed.
#  The .env file is gitignored and will NOT be committed.
# ════════════════════════════════════════════════════════════════

# ── Directories ──────────────────────────────────────────────────
# Where uploaded PDFs are stored (relative to project root)
DATA_DIR=data

# Where ChromaDB persists its files (relative to project root)
CHROMA_DIR=data/chroma_db

# ── Default App Settings ─────────────────────────────────────────
# These are the sidebar defaults when the app starts.
# Options: 300 | 700
DEFAULT_CHUNK_SIZE=300

# Options: 50 | 75 | 100
DEFAULT_OVERLAP=75

# Options: all-MiniLM-L6-v2 | bge-base-en-v1.5
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Options: FAISS | ChromaDB
DEFAULT_VECTOR_STORE=FAISS

# Options: FLAN-T5-Base (Fast) | FLAN-T5-Large
DEFAULT_LLM=FLAN-T5-Base (Fast)

# Options: 2-10
DEFAULT_TOP_K=5

# ── HuggingFace (Optional) ───────────────────────────────────────
# Only needed if you want to use private/gated HuggingFace models.
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# ── Windows Compatibility Fixes ──────────────────────────────────
# Suppresses duplicate OpenMP runtime warning (harmless on Windows).
KMP_DUPLICATE_LIB_OK=TRUE

# Avoids HuggingFace tokenizer parallelism warning.
TOKENIZERS_PARALLELISM=false

# ── Streamlit Server (Optional) ──────────────────────────────────
# Uncomment to change the default port.
# STREAMLIT_SERVER_PORT=8501
