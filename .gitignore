# ── Virtual Environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Python Cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Distribution / Build ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Data — Uploaded PDFs (user-specific, potentially large/private) ───────────
data/*.pdf
*.pdf

# ── ChromaDB persistent store (auto-generated, large binary files) ────────────
data/chroma_db/

# ── HuggingFace model cache (hundreds of MB, downloaded automatically) ────────
~/.cache/huggingface/
.cache/

# ── Streamlit config / cache ──────────────────────────────────────────────────
.streamlit/

# ── Pytest / test scratch files ───────────────────────────────────────────────
scratch/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment variables / secrets ──────────────────────────────────────────
# Keep .env.example (safe template) but ignore the real .env (has local values)
.env
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test / coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
